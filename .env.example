# ChronoTrack backend environment (copy to .env.local for dev; set in Vercel for prod)

# Neon Postgres connection string (prod). For local docker test use:
#   DATABASE_URL=postgres://postgres:test@localhost:5544/chronotrack  PGSSL=disable
DATABASE_URL=

# Disable TLS only for local non-TLS Postgres. NEVER set in production.
# PGSSL=disable

# JWT signing secret — REQUIRED in production (app refuses to boot without it).
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_TTL=8h

# Comma-separated allowed CORS origins (web app + Electron). REQUIRED in prod.
# e.g. ALLOWED_ORIGINS=https://chronotrack.vercel.app,app://.
ALLOWED_ORIGINS=

# DPDP consent version recorded at activation.
CONSENT_VERSION=1.0

# One-time admin bootstrap (used by scripts/seed-admin.js, not at runtime):
# COMPANY="Civil Mantra"
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME="Administrator"

# Retention cron (Vercel Cron hits /api/reports daily with this bearer).
# Vercel injects CRON_SECRET automatically when a cron is configured; set the same
# value here if self-hosting. RETENTION_DAYS = telemetry older than this is pruned.
CRON_SECRET=
RETENTION_DAYS=180
