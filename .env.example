# ChronoTrack backend environment (copy to .env.local for dev; set in Vercel for prod)

# Neon Postgres connection string (prod). For local docker test use:
#   DATABASE_URL=postgres://postgres:test@localhost:5544/chronotrack  PGSSL=disable
DATABASE_URL=

# Disable TLS only for local non-TLS Postgres. NEVER set in production.
# PGSSL=disable

# JWT signing secret — REQUIRED in production (app refuses to boot without it).
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_TTL=8h
# Zero-downtime rotation: set JWT_SECRET to the new value and put the OLD one
# here. Tokens signed with the previous secret keep verifying until they expire.
JWT_SECRET_PREVIOUS=

# Scale hardening (all optional — sensible defaults if unset):
# Shared rate-limit store so limits hold across serverless instances. Without
# these the limiter is per-instance in-memory (fine for dev / small deploys).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Device bearer-token lifetime (days). Re-activation rotates the token.
DEVICE_TOKEN_TTL_DAYS=180
# Ingest backpressure: max concurrent ingest requests per instance before 503.
INGEST_MAX_INFLIGHT=40
# Postgres pool (per instance). Use the Neon POOLED connection string at scale.
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=10000

# Comma-separated allowed CORS origins (web app + Electron). REQUIRED in prod.
# e.g. ALLOWED_ORIGINS=https://chronotrack.vercel.app,app://.
ALLOWED_ORIGINS=

# DPDP consent version recorded at activation.
CONSENT_VERSION=1.0

# One-time admin bootstrap (used by scripts/seed-admin.js, not at runtime):
# COMPANY="ChronoTrack"
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME="Administrator"

# Retention cron (Vercel Cron hits /api/reports daily with this bearer).
# Vercel injects CRON_SECRET automatically when a cron is configured; set the same
# value here if self-hosting. RETENTION_DAYS = telemetry older than this is pruned.
CRON_SECRET=
RETENTION_DAYS=180
