{
  "name": "chronotrack",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "main": "main.cjs",
  "author": {
    "name": "Civil Mantra",
    "email": "agent@civilmantra.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "build:daemon": "bash src-daemon/build_daemon.sh",
    "electron:build": "npm run build && npm run build:daemon && electron-builder",
    "migrate": "node scripts/migrate.js",
    "seed:admin": "node scripts/seed-admin.js",
    "test:api": "node scripts/test-api.js",
    "test:daemon": "bash scripts/test-daemon-e2e.sh",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.civilmantra.agent",
    "productName": "CivilMantraAgent",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ],
    "extraResources": [
      {
        "from": "dist-daemon",
        "to": "daemon",
        "filter": [
          "CivilMantraDaemon*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "civilmantra",
        "repo": "agent-client"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "public/logo.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "public/logo.png"
    }
  }
}
